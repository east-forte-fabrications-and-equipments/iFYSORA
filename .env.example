# Server Configuration
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://your-domain.com

# Database - Use environment-specific URLs
DATABASE_URL=postgresql://user:password@host:5432/ifysora

# JWT - MUST be changed in production
JWT_SECRET=generate-a-strong-secret-here
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# FYSORA Ecosystem API
FYSORA_FASHN_API_URL=https://api.fysora-fashn.com
FYSORA_FASHN_API_KEY=your-production-api-key

# Google Gemini AI
GEMINI_API_KEY=your-production-gemini-key
GEMINI_MODEL=gemini-2.0-flash-exp

# Redis (for production)
REDIS_URL=redis://redis:6379

# CORS - Update with your production domains
ALLOWED_ORIGINS=https://your-domain.com,https://ifysora.fysora.com

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Verification
EMAIL_VERIFICATION_EXPIRY=86400

# Cloud Provider OAuth Credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-secret
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
ONEDRIVE_CLIENT_ID=your-onedrive-client-id
ONEDRIVE_CLIENT_SECRET=your-onedrive-client-secret

# WhatsApp Business API (optional)
WHATSAPP_BUSINESS_PHONE_ID=your-whatsapp-phone-id
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-token

# Security
SESSION_SECRET=your-session-secret
ENCRYPTION_KEY=your-encryption-key-for-cloud-tokens
